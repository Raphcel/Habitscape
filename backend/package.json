{
  "name": "habitscape-backend",
  "version": "1.0.0",
  "description": "Habitscape Express.js API — raw SQL with pg",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node -e \"require('dotenv').config(); const {pool}=require('./src/config/database'); const fs=require('fs'); pool.query(fs.readFileSync('./src/db/schema.sql','utf8')).then(()=>{console.log('Schema applied ✓');process.exit(0);}).catch(e=>{console.error(e);process.exit(1);})\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.9.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.15.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
